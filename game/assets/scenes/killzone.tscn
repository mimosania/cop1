[gd_scene format=3 uid="uid://cunoynxwdr3em"]

[sub_resource type="GDScript" id="GDScript_7iukr"]
script/source = "extends Area2D

@onready var timer: Timer = $Timer

func _on_body_entered(body) -> void:
	timer.start()
	Engine.time_scale = 0.5
func _on_timer_timeout() -> void:
	get_tree().reload_current_scene()
	Engine.time_scale = 1
"

[node name="Killzone" type="Area2D" unique_id=463157565]
collision_mask = 2
script = SubResource("GDScript_7iukr")

[node name="Timer" type="Timer" parent="." unique_id=1472428611]
wait_time = 1.5
one_shot = true

[connection signal="body_entered" from="." to="." method="_on_body_entered"]
[connection signal="timeout" from="Timer" to="." method="_on_timer_timeout"]
